rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Validation blueprints
    function isValidUserProfile(data) {
      return data.keys().hasAll(['displayName', 'theme', 'updatedAt'])
        && data.keys().size() == 3
        && data.displayName is string
        && data.displayName.size() >= 1
        && data.displayName.size() <= 100
        && (data.theme == 'light' || data.theme == 'dark')
        && data.updatedAt is string && data.updatedAt.size() <= 40;
    }

    function isValidUserPrivateInfo(data) {
      return data.keys().hasAll(['email', 'encryptedData', 'updatedAt'])
        && data.keys().size() == 3
        && data.email is string
        && data.email.size() >= 3
        && data.email.size() <= 200
        && data.encryptedData is string
        && data.encryptedData.size() <= 10000
        && data.updatedAt is string && data.updatedAt.size() <= 40;
    }

    function isValidTask(data) {
      return data.keys().hasAll(['title', 'priority', 'status', 'dueDate', 'createdAt', 'updatedAt'])
        && data.title is string
        && data.title.size() >= 1
        && data.title.size() <= 200
        && (data.priority == 'high' || data.priority == 'medium' || data.priority == 'low')
        && (data.status == 'pending' || data.status == 'completed')
        && data.dueDate is string
        && data.dueDate.size() <= 50;
    }

    function isValidHabit(data) {
      return data.keys().hasAll(['title', 'frequency', 'streak', 'logs', 'createdAt', 'updatedAt'])
        && data.title is string
        && data.title.size() >= 1
        && data.title.size() <= 200
        && data.frequency is string
        && data.frequency.size() <= 50
        && data.streak is int
        && data.streak >= 0
        && data.logs is list
        && data.logs.size() <= 1000;
    }

    function isValidGoal(data) {
      return data.keys().hasAll(['title', 'targetDate', 'progress', 'createdAt', 'updatedAt'])
        && data.title is string
        && data.title.size() >= 1
        && data.title.size() <= 200
        && data.targetDate is string
        && data.targetDate.size() <= 50
        && data.progress is int
        && data.progress >= 0
        && data.progress <= 100;
    }

    function isValidRecommendation(data) {
      return data.keys().hasAll(['content', 'category', 'createdAt'])
        && data.content is string
        && data.content.size() <= 5000
        && data.category is string
        && data.category.size() <= 100;
    }

    // Rules for User Profile
    match /users/{userId}/public/profile {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create, update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    // Rules for Private Info
    match /users/{userId}/private/secure_info {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create, update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    // Rules for Tasks
    match /users/{userId}/tasks/{taskId} {
      allow get: if isOwner(userId) && isValidId(taskId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId) && isValidId(taskId) && isValidTask(incoming())
                     && incoming().createdAt is string && incoming().createdAt.size() <= 40
                     && incoming().updatedAt is string && incoming().updatedAt.size() <= 40;
      allow update: if isOwner(userId) && isValidId(taskId) && isValidTask(incoming())
                     && incoming().createdAt == existing().createdAt
                     && incoming().updatedAt is string && incoming().updatedAt.size() <= 40;
      allow delete: if isOwner(userId) && isValidId(taskId);
    }

    // Rules for Habits
    match /users/{userId}/habits/{habitId} {
      allow get: if isOwner(userId) && isValidId(habitId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId) && isValidId(habitId) && isValidHabit(incoming())
                     && incoming().createdAt is string && incoming().createdAt.size() <= 40
                     && incoming().updatedAt is string && incoming().updatedAt.size() <= 40;
      allow update: if isOwner(userId) && isValidId(habitId) && isValidHabit(incoming())
                     && incoming().createdAt == existing().createdAt
                     && incoming().updatedAt is string && incoming().updatedAt.size() <= 40;
      allow delete: if isOwner(userId) && isValidId(habitId);
    }

    // Rules for Goals
    match /users/{userId}/goals/{goalId} {
      allow get: if isOwner(userId) && isValidId(goalId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId) && isValidId(goalId) && isValidGoal(incoming())
                     && incoming().createdAt is string && incoming().createdAt.size() <= 40
                     && incoming().updatedAt is string && incoming().updatedAt.size() <= 40;
      allow update: if isOwner(userId) && isValidId(goalId) && isValidGoal(incoming())
                     && incoming().createdAt == existing().createdAt
                     && incoming().updatedAt is string && incoming().updatedAt.size() <= 40;
      allow delete: if isOwner(userId) && isValidId(goalId);
    }

    // Rules for Recommendations
    match /users/{userId}/recommendations/{recId} {
      allow get: if isOwner(userId) && isValidId(recId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId) && isValidId(recId) && isValidRecommendation(incoming())
                     && incoming().createdAt is string && incoming().createdAt.size() <= 40;
      allow update: if isOwner(userId) && isValidId(recId) && isValidRecommendation(incoming());
      allow delete: if isOwner(userId) && isValidId(recId);
    }
  }
}
